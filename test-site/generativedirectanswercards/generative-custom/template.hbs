<div class="HitchhikerGenerativeStandard {{cardName}}">
    {{#if (eq searchState 'search-loading')}}
        <div class="HitchhikerGenerativeStandard-title">
            <h2 class="HitchhikerGenerativeStandard-titleText">
                AI Generating Answer...
            </h2>
        </div>
    {{else if success}}
        <div class="HitchhikerGenerativeStandard-title">
            <h2 class="yxt-GenerativeDirectAnswer-titleText">
                AI Generated Answer
            </h2>
            <div class="HitchhikerGenerativeStandard-aiSignpost">
                <button
                    class="HitchhikerGenerativeStandard-aiSignpostButton js-yxt-GenerativeDirectAnswer-aiSignpostButton"
                    type="button"
                    aria-expanded="false"
                    aria-label="{{translate phrase='AI-Generated Content' }}"
                    aria-controls="yxt-GenerativeDirectAnswer-aiSignpostPopover-{{cardName}}">
                    <svg
                        class="HitchhikerGenerativeStandard-aiSignpostIcon"
                        viewBox="0 0 20 20"
                        aria-hidden="true">
                        <path
                            fill="currentColor"
                            d="M16.5 2C17.3284 2 18 2.67157 18 3.5V16.5C18 17.3284 17.3284 18 16.5 18H3.5C2.67157 18 2 17.3284 2 16.5V3.5C2 2.67157 2.67157 2 3.5 2H16.5ZM6.73145 6L4.5 13.29H5.52051L6.04785 11.3906H8.60156L9.13867 13.29H10.1592L7.92773 6H6.73145ZM11.3262 6V6.83008H12.8545V12.46H11.3262V13.29H15.374V12.46H13.8457V6.83008H15.374V6H11.3262ZM8.36719 10.5996H6.28711L7.32715 6.86914L8.36719 10.5996Z">
                        </path>
                    </svg>
                </button>
                <div
                    class="HitchhikerGenerativeStandard-aiSignpostPopover js-yxt-GenerativeDirectAnswer-aiSignpostPopover"
                    id="yxt-GenerativeDirectAnswer-aiSignpostPopover-{{cardName}}"
                    role="dialog"
                    aria-labelledby="yxt-GenerativeDirectAnswer-aiSignpostPopoverHeader-{{cardName}}"
                    aria-describedby="yxt-GenerativeDirectAnswer-aiSignpostPopoverBody-{{cardName}}"
                    hidden>
                    <div class="HitchhikerGenerativeStandard-aiSignpostPopoverHeader">
                        <div
                            class="HitchhikerGenerativeStandard-aiSignpostPopoverHeaderText"
                            id="yxt-GenerativeDirectAnswer-aiSignpostPopoverHeader-{{cardName}}">
                            {{translate phrase='AI-Generated Content' }}
                        </div>
                        <button
                            class="HitchhikerGenerativeStandard-aiSignpostClose js-yxt-GenerativeDirectAnswer-aiSignpostClose"
                            type="button"
                            aria-label="{{translate phrase='Dismiss' }}">
                            {{> icons/builtInIcon iconName='close'}}
                        </button>
                    </div>
                    <div
                        class="HitchhikerGenerativeStandard-aiSignpostPopoverBody"
                        id="yxt-GenerativeDirectAnswer-aiSignpostPopoverBody-{{cardName}}">
                        This answer was generated by AI from matching search results and may be incomplete or inaccurate. Review the matching results for full context.
                    </div>
                </div>
            </div>
        </div>
        <div class="HitchhikerGenerativeStandard-content">
            <div class="yxt-GenerativeDirectAnswer-snippet">
                {{{ generativeDirectAnswer }}}
            </div>
            <hr class="HitchhikerGenerativeStandard-citationsDivider" noshade>
            <h2 class="HitchhikerGenerativeStandard-citationsHeader">
                Sources ({{citationsData.length}})
            </h2>
            <div class="HitchhikerGenerativeStandard-citationsScroller">
                {{#each citationsData}}
                    {{> citation_card citation=this sourceUrlFields=../sourceUrlFields linkTarget=../linkTarget}}
                {{/each}}
            </div>
        </div>
        {{> thumbsfeedback directAnswerClass="HitchhikerGenerativeStandard" isGDA=true}}
    {{/if}}
</div>


{{#*inline 'citation_card'}}
<a class="HitchhikerGenerativeStandard-citationCard js-HitchhikerGDACard-citation"
    {{getGdaSourceUrlHref sourceUrlFields citation.rawData}}
    data-entityid={{citation.id}}
    data-eventtype="CITATION_CLICK"
    data-is-analytics-attached="true"
    target={{#if linkTarget}}"{{linkTarget}}"{{else}}"_blank"{{/if}}
    >
    <span class="HitchhikerGenerativeStandard-citationName">{{citation.name}}</span>
    {{#if citation.description}}
        <p class="HitchhikerGenerativeStandard-citationDescription">{{citation.description}}</p>
    {{/if}}
</a>
{{/inline}}
